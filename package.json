{
  "name": "md-preview",
  "displayName": "Markdown Previewer Plus",
  "description": "Live Markdown preview with auto-refresh and scroll sync.",
  "version": "0.0.2",
  "publisher": "ParthPatel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/parthpatel021/md-preview"
  },
  "bugs": {
    "url": "https://github.com/parthpatel021/md-preview/issues"
  },
  "homepage": "https://github.com/parthpatel021/md-preview#readme",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "assets/parthpatel.jpeg",
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "md-preview.openPreview",
        "title": "Open Markdown Preview"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "vsce:package": "vsce package",
    "vsce:publish": "vsce publish"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  },
  "dependencies": {
    "marked": "^17.0.3"
  }
}
